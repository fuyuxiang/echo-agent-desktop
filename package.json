{
  "name": "echo-agent-desktop",
  "version": "0.1.0",
  "description": "Echo Agent 桌面客户端(macOS / Windows)",
  "type": "module",
  "main": "out/main/index.js",
  "author": "Echo",
  "homepage": "https://echo.example.com",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build": "npm run typecheck && electron-vite build",
    "build:unpack": "npm run build && electron-builder --dir",
    "fetch:python": "node scripts/fetch-python.mjs",
    "fetch:asr": "node scripts/fetch-asr.mjs",
    "build:mac": "node scripts/fetch-python.mjs --all-mac && node scripts/fetch-asr.mjs && npm run build && electron-builder --mac",
    "build:win": "node scripts/fetch-python.mjs --platform win && node scripts/fetch-asr.mjs && npm run build && electron-builder --win",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "new:page": "plop --plopfile scripts/plopfile.mjs",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky",
    "test": "vitest run"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.10.0",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "electron-window-state": "^5.0.3",
    "sherpa-onnx-node": "^1.13.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@hookform/resolvers": "^5.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "ahooks": "^3.9.7",
    "axios": "^1.17.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "framer-motion": "^12.40.0",
    "husky": "^9.1.7",
    "i18next": "^26.3.1",
    "immer": "^11.1.8",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "lodash-es": "^4.18.1",
    "mitt": "^3.0.1",
    "nanoid": "^5.1.11",
    "plop": "^4.0.5",
    "prettier": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1",
    "sass": "^1.100.0",
    "shiki": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.5",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.9",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
